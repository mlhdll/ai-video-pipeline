# --- Krea AI (Image Generation) ---
# Format: ID:SECRET (Two strings separated by a colon)
KREA_API_KEY=your_krea_id:your_krea_secret
# Default is 'z-image'. You can also use 'flux' or other models supported by Krea.
KREA_MODEL=z-image

# --- Google Gemini AI (Plan & Metadata Generation) ---
GEMINI_API_KEY=your_gemini_api_key
GEMINI_TEXT_MODEL=gemini-2.5-flash-lite

# --- Groq AI (Dynamic Word-Level Subtitles) ---
GROQ_API_KEY=your_groq_api_key

# --- Text-to-Speech (Microsoft Edge) ---
# Example voices: en-US-ChristopherNeural, en-US-GuyNeural, en-GB-RyanNeural, etc.
TTS_VOICE=en-US-ChristopherNeural

# --- YouTube Upload Settings ---
# Set your channel URL for faster navigation
YOUTUBE_CHANNEL_URL=https://studio.youtube.com/channel/YOUR_CHANNEL_ID
